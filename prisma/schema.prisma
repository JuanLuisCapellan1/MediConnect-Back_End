generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Usuario {
  id                      Int                   @id @default(autoincrement()) @map("id_usuario")
  email                   String                @unique(map: "uq_usuarios_email") @db.VarChar(120)
  password                String                @map("contrasena") @db.VarChar(255)
  fotoPerfil              String?               @map("foto_perfil")
  telefono                String?               @db.VarChar(20)
  rol                     String                @db.VarChar(30)
  emailVerificado         Boolean               @default(false) @map("email_verificado")
  estado                  String                @default("Activo") @db.VarChar(20)
  creadoEn                DateTime              @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn           DateTime?             @map("actualizado_en") @db.Timestamptz(6)
  banner                  String?
  accionesRevisadas       Accion[]              @relation("RevisorAccion")
  accionesEmitidas        Accion[]              @relation("EmisorAccion")
  centroSalud             CentroSalud?
  conversacionesIniciadas Conversacion[]        @relation("EmisorConversacion")
  conversacionesRecibidas Conversacion[]        @relation("ReceptorConversacion")
  cuentasSociales         CuentaSocial[]
  doctor                  Doctor?
  lecturasConversacion    LecturaConversacion[]
  mensajesEnviados        Mensaje[]             @relation("RemitenteMensaje")
  notificaciones          Notificacion[]
  paciente                Paciente?

  @@map("usuarios")
}

model CuentaSocial {
  id           Int      @id @default(autoincrement()) @map("id_cuenta_social")
  usuarioId    Int      @map("id_usuario")
  proveedor    String   @db.VarChar(50)
  uidProveedor String   @map("uid_proveedor") @db.VarChar(255)
  creadoEn     DateTime @default(now()) @map("creado_en") @db.Timestamptz(6)
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([proveedor, uidProveedor])
  @@unique([usuarioId, proveedor])
  @@map("cuentas_sociales")
}

model Paciente {
  usuarioId                       Int                      @id @map("id_usuario")
  nombre                          String                   @db.VarChar(80)
  apellido                        String                   @db.VarChar(80)
  tipoDocIdentificacion           String                   @default("Cédula") @map("tipo_documento_identificacion") @db.VarChar(20)
  numero_documento_identificacion String                   @unique(map: "uq_pacientes_numero_doc") @db.VarChar(20)
  foto_documento                  String?                  @unique(map: "pacientes_documento_identificacion_key")
  fechaNacimiento                 DateTime                 @map("fecha_nacimiento") @db.Date
  genero                          String                   @db.Char(1)
  peso                            Decimal?                 @db.Decimal(5, 2)
  tipoSangre                      String?                  @map("tipo_sangre") @db.VarChar(5)
  ubicacionId                     Int?                     @map("id_ubicacion")
  estado                          String                   @default("Activo") @db.VarChar(20)
  creadoEn                        DateTime                 @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn                   DateTime?                @map("actualizado_en") @db.Timestamptz(6)
  altura                          Int?
  caracteristicas                 CaracteristicaEspecial[]
  citas                           Cita[]
  doctoresFavoritos               DoctorFavorito[]
  historiales                     HistorialConsulta[]
  ubicacion                       Ubicacion?               @relation(fields: [ubicacionId], references: [id])
  usuario                         Usuario                  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  seguros                         PacienteSeguro[]
  resenas                         Resena[]

  @@map("pacientes")
}

model Doctor {
  usuarioId                     Int                      @id @map("id_usuario")
  ubicacionId                   Int?                     @map("id_ubicacion")
  nombre                        String                   @db.VarChar(80)
  apellido                      String                   @db.VarChar(80)
  tipoDocIdentificacion         String                   @default("Cédula") @map("tipo_documento_identificacion") @db.VarChar(20)
  numeroDocumentoIdentificacion String                   @unique(map: "uq_doctores_numero_doc") @map("numero_documento_identificacion") @db.VarChar(20)
  fechaNacimiento               DateTime                 @map("fecha_nacimiento") @db.Date
  genero                        String                   @db.Char(1)
  nacionalidad                  String?                  @db.VarChar(50)
  exequatur                     String                   @unique @db.VarChar(40)
  biografia                     String?
  anosExperiencia               Int?                     @map("anos_experiencia")
  estadoVerificacion            String                   @default("En revisión") @map("estado_verificacion") @db.VarChar(20)
  calificacionPromedio          Decimal?                 @default(0.00) @map("calificacion_promedio") @db.Decimal(3, 2)
  estado                        String                   @default("Activo") @db.VarChar(20)
  creadoEn                      DateTime                 @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn                 DateTime?                @map("actualizado_en") @db.Timestamptz(6)
  duracionCitaPromedio          Int                      @default(30) @map("duracion_cita_promedio")
  tarifas                       Decimal?                 @db.Decimal(10, 2)
  caracteristicas_especiales    CaracteristicaEspecial[]
  citas                         Cita[]                   @relation("DoctorCita")
  usuario                       Usuario                  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  ubicacion                     Ubicacion?               @relation(fields: [ubicacionId], references: [id], onUpdate: NoAction, map: "fk_doctores_ubicacion")
  especialidades                DoctorEspecialidad[]
  favoritosDe                   DoctorFavorito[]
  idiomas                       DoctorIdioma[]
  segurosAceptados              DoctorSeguro[]
  documentos                    DocumentoDoctor[]
  experiencias                  ExperienciaLaboral[]
  formaciones                   FormacionAcademica[]
  horarios                      Horario[]
  resenas                       Resena[]
  servicios                     Servicio[]
  solicitudesAlianza            SolicitudAlianza[]

  @@index([ubicacionId], map: "idx_doctores_ubicacion")
  @@map("doctores")
}

model CentroSalud {
  usuarioId               Int                       @id @map("id_usuario")
  nombreComercial         String                    @map("nombre_comercial") @db.VarChar(120)
  rnc                     String?                   @unique @db.VarChar(20)
  tipoCentroId            Int                       @map("id_tipo_centro")
  ubicacionId             Int                       @map("id_ubicacion")
  estadoVerificacion      String                    @default("En revisión") @map("estado_verificacion") @db.VarChar(20)
  estado                  String                    @default("Activo") @db.VarChar(20)
  creadoEn                DateTime                  @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn           DateTime?                 @map("actualizado_en") @db.Timestamptz(6)
  certificacion_sanitaria String?
  sitio_web               String?
  descripcion             String?
  foto_perfil             String?
  tipoCentro              TipoCentroSalud           @relation(fields: [tipoCentroId], references: [id])
  ubicacion               Ubicacion                 @relation(fields: [ubicacionId], references: [id])
  usuario                 Usuario                   @relation(fields: [usuarioId], references: [id])
  horarios                Horario[]
  servicios_centros_salud servicios_centros_salud[]
  solicitudesAlianza      SolicitudAlianza[]

  @@map("centros_salud")
}

model Pais {
  id            Int           @id @default(autoincrement()) @map("id_pais")
  nombre        String        @unique @db.VarChar(80)
  estado        String        @default("Activo") @db.VarChar(20)
  creadoEn      DateTime      @default(now()) @map("creado_en") @db.Timestamptz(6)
  codigo_iso    String?       @db.VarChar(2)
  universidades Universidad[]

  @@index([codigo_iso], map: "idx_paises_codigo_iso")
  @@index([nombre], map: "idx_paises_nombre")
  @@map("paises")
}

model Provincia {
  id         Int         @id @default(autoincrement()) @map("id_provincia")
  nombre     String      @unique @db.VarChar(80)
  estado     String      @default("Activo") @db.VarChar(20)
  creadoEn   DateTime    @default(now()) @map("creado_en") @db.Timestamptz(6)
  municipios Municipio[]

  @@map("provincias")
}

model Municipio {
  id                   Int                 @id @default(autoincrement()) @map("id_municipio")
  provinciaId          Int                 @map("id_provincia")
  nombre               String              @db.VarChar(80)
  estado               String              @default("Activo") @db.VarChar(20)
  creadoEn             DateTime            @default(now()) @map("creado_en") @db.Timestamptz(6)
  distritosMunicipales DistritoMunicipal[]
  provincia            Provincia           @relation(fields: [provinciaId], references: [id])

  @@unique([provinciaId, nombre])
  @@map("municipios")
}

model DistritoMunicipal {
  id          Int       @id @default(autoincrement()) @map("id_distrito_municipal")
  municipioId Int       @map("id_municipio")
  nombre      String    @db.VarChar(80)
  estado      String    @default("Activo") @db.VarChar(20)
  creadoEn    DateTime  @default(now()) @map("creado_en") @db.Timestamptz(6)
  municipio   Municipio @relation(fields: [municipioId], references: [id])
  secciones   Seccion[]

  @@unique([municipioId, nombre])
  @@map("distritos_municipales")
}

model Seccion {
  id                  Int                @id @default(autoincrement()) @map("id_seccion")
  distritoMunicipalId Int?               @map("id_distrito_municipal")
  nombre              String             @db.VarChar(80)
  estado              String             @default("Activo") @db.VarChar(20)
  creadoEn            DateTime           @default(now()) @map("creado_en") @db.Timestamptz(6)
  id_municipio        Int?
  barrios             Barrio[]
  distritoMunicipal   DistritoMunicipal? @relation(fields: [distritoMunicipalId], references: [id], onDelete: Restrict)

  @@unique([distritoMunicipalId, nombre])
  @@map("secciones")
}

model Barrio {
  id          Int         @id @default(autoincrement()) @map("id_barrio")
  seccionId   Int         @map("id_seccion")
  nombre      String      @db.VarChar(80)
  estado      String      @default("Activo") @db.VarChar(20)
  creadoEn    DateTime    @default(now()) @map("creado_en") @db.Timestamptz(6)
  seccion     Seccion     @relation(fields: [seccionId], references: [id])
  subBarrios  SubBarrio[]
  ubicaciones Ubicacion[]

  @@unique([seccionId, nombre])
  @@map("barrios")
}

model SubBarrio {
  id          Int         @id @default(autoincrement()) @map("id_sub_barrio")
  barrioId    Int         @map("id_barrio")
  nombre      String      @db.VarChar(80)
  estado      String      @default("Activo") @db.VarChar(20)
  creadoEn    DateTime    @default(now()) @map("creado_en") @db.Timestamptz(6)
  barrio      Barrio      @relation(fields: [barrioId], references: [id])
  ubicaciones Ubicacion[]

  @@map("sub_barrios")
}

model Ubicacion {
  id              Int                      @id @default(autoincrement()) @map("id_ubicacion")
  barrioId        Int                      @map("id_barrio")
  subBarrioId     Int?                     @map("id_sub_barrio")
  direccion       String                   @db.VarChar(255)
  codigoPostal    String?                  @map("codigo_postal") @db.VarChar(10)
  puntoGeografico Unsupported("geometry")? @map("punto_geografico")
  estado          String                   @default("Activo") @db.VarChar(20)
  creadoEn        DateTime                 @default(now()) @map("creado_en") @db.Timestamptz(6)
  centrosSalud    CentroSalud[]
  citas           Cita[]
  doctores        Doctor[]
  horarios        Horario[]
  pacientes       Paciente[]
  servicios       Servicio[]
  barrio          Barrio                   @relation(fields: [barrioId], references: [id])
  subBarrio       SubBarrio?               @relation(fields: [subBarrioId], references: [id])

  @@index([puntoGeografico], map: "idx_ubicaciones_geom", type: Gist)
  @@map("ubicaciones")
}

model Especialidad {
  id          Int                  @id @default(autoincrement()) @map("id_especialidad")
  nombre      String               @unique @db.VarChar(80)
  descripcion String?
  estado      String               @default("Activo") @db.VarChar(20)
  creadoEn    DateTime             @default(now()) @map("creado_en") @db.Timestamptz(6)
  doctores    DoctorEspecialidad[]
  servicios   Servicio[]

  @@map("especialidades")
}

model Universidad {
  id          Int                  @id @default(autoincrement()) @map("id_universidad")
  paisId      Int                  @map("id_pais")
  nombre      String               @db.VarChar(120)
  estado      String               @default("Activo") @db.VarChar(20)
  creadoEn    DateTime             @default(now()) @map("creado_en") @db.Timestamptz(6)
  formaciones FormacionAcademica[]
  pais        Pais                 @relation(fields: [paisId], references: [id])

  @@unique([nombre, paisId])
  @@map("universidades")
}

model TipoCentroSalud {
  id       Int           @id @default(autoincrement()) @map("id_tipo_centro_salud")
  nombre   String        @db.VarChar(80)
  estado   String        @default("Activo") @db.VarChar(20)
  creadoEn DateTime      @default(now()) @map("creado_en") @db.Timestamptz(6)
  centros  CentroSalud[]

  @@map("tipos_centros_salud")
}

model TipoServicio {
  id          Int        @id @default(autoincrement()) @map("id_tipo_servicio")
  nombre      String     @db.VarChar(80)
  descripcion String?
  estado      String     @default("Activo") @db.VarChar(20)
  creadoEn    DateTime   @default(now()) @map("creado_en") @db.Timestamptz(6)
  servicios   Servicio[]

  @@map("tipos_servicios")
}

model CondicionMedica {
  id              Int                      @id @default(autoincrement()) @map("id_condicion")
  nombre          String?                  @unique @db.VarChar(100)
  descripcion     String?
  tipo            String                   @default("Enfermedad") @db.VarChar(30)
  estado          String                   @default("Activa") @db.VarChar(20)
  creadoEn        DateTime                 @default(now()) @map("creado_en") @db.Timestamptz(6)
  caracteristicas CaracteristicaEspecial[]

  @@map("condiciones_medicas")
}

model SeguroMedico {
  id        Int              @id @default(autoincrement()) @map("id_seguro")
  nombre    String           @unique @db.VarChar(120)
  urlImage  String?          @map("url_image")
  estado    String           @default("Activo") @db.VarChar(20)
  creadoEn  DateTime         @default(now()) @map("creado_en") @db.Timestamptz(6)
  doctores  DoctorSeguro[]
  pacientes PacienteSeguro[]

  @@map("seguros_medicos")
}

model TipoSeguro {
  id          Int              @id @default(autoincrement()) @map("id_tipo_seguro")
  nombre      String           @unique @db.VarChar(80)
  descripcion String?
  estado      String           @default("Activo") @db.VarChar(20)
  creadoEn    DateTime         @default(now()) @map("creado_en") @db.Timestamptz(6)
  doctores    DoctorSeguro[]
  pacientes   PacienteSeguro[]

  @@map("tipos_seguros")
}

model FormacionAcademica {
  id                 Int         @id @default(autoincrement()) @map("id_formacion")
  doctorId           Int         @map("id_doctor")
  universidadId      Int         @map("id_universidad")
  fecha_inicio       DateTime    @db.Date
  fecha_finalizacion DateTime?   @db.Date
  estado             String      @default("Activo") @db.VarChar(20)
  creadoEn           DateTime    @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn      DateTime?   @map("actualizado_en") @db.Timestamptz(6)
  nombre             String      @default("Sin especificar") @db.VarChar(150)
  enCurso            Boolean     @default(false) @map("en_curso")
  doctor             Doctor      @relation(fields: [doctorId], references: [usuarioId])
  universidad        Universidad @relation(fields: [universidadId], references: [id])

  @@unique([doctorId, universidadId, nombre], map: "uq_formacion_detalle_nuevo")
  @@index([doctorId, estado, enCurso], map: "idx_formaciones_doctor_activas")
  @@index([universidadId], map: "idx_formaciones_universidad")
  @@map("formaciones_academicas")
}

model ExperienciaLaboral {
  id                 Int       @id @default(autoincrement()) @map("id_experiencia")
  doctorId           Int       @map("id_doctor")
  institucion        String    @db.VarChar(150)
  fechaInicio        DateTime  @map("fecha_inicio") @db.Date
  fechaFinalizacion  DateTime? @map("fecha_finalizacion") @db.Date
  trabajaActualmente Boolean   @default(false) @map("trabaja_actualmente")
  estado             String    @default("Activo") @db.VarChar(20)
  creadoEn           DateTime  @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn      DateTime? @map("actualizado_en") @db.Timestamptz(6)
  posicion           String    @db.VarChar(100)
  doctor             Doctor    @relation(fields: [doctorId], references: [usuarioId])

  @@map("experiencias_laborales")
}

model SolicitudAlianza {
  id            Int         @id @default(autoincrement()) @map("id_solicitud")
  doctorId      Int         @map("id_doctor")
  centroSaludId Int         @map("id_centro_salud")
  mensaje       String?     @db.VarChar(255)
  estado        String      @default("Pendiente") @db.VarChar(20)
  motivoRechazo String?     @map("motivo_rechazo")
  iniciadaPor   String      @default("Centro") @map("iniciada_por") @db.VarChar(10)
  creadoEn      DateTime    @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn DateTime?   @map("actualizado_en") @db.Timestamptz(6)
  centroSalud   CentroSalud @relation(fields: [centroSaludId], references: [usuarioId])
  doctor        Doctor      @relation(fields: [doctorId], references: [usuarioId])

  @@unique([doctorId, centroSaludId, estado])
  @@map("solicitudes_alianza")
}

model DoctorFavorito {
  pacienteId Int      @map("id_paciente")
  doctorId   Int      @map("id_doctor")
  agregadoEn DateTime @default(now()) @map("agregado_en") @db.Timestamptz(6)
  estado     String   @default("Activo") @db.VarChar(20)
  doctor     Doctor   @relation(fields: [doctorId], references: [usuarioId])
  paciente   Paciente @relation(fields: [pacienteId], references: [usuarioId])

  @@id([pacienteId, doctorId])
  @@map("doctores_favoritos")
}

model DoctorSeguro {
  doctorId      Int          @map("id_usuario")
  seguroId      Int          @map("id_seguro")
  tipoSeguroId  Int          @map("id_tipo_seguro")
  estado        String       @default("Activo") @db.VarChar(20)
  creadoEn      DateTime     @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn DateTime?    @map("actualizado_en") @db.Timestamptz(6)
  seguro        SeguroMedico @relation(fields: [seguroId], references: [id])
  tipoSeguro    TipoSeguro   @relation(fields: [tipoSeguroId], references: [id])
  doctor        Doctor       @relation(fields: [doctorId], references: [usuarioId])

  @@id([doctorId, seguroId, tipoSeguroId])
  @@map("doctores_seguros")
}

model PacienteSeguro {
  pacienteId    Int          @map("id_usuario")
  seguroId      Int          @map("id_seguro")
  tipoSeguroId  Int          @map("id_tipo_seguro")
  estado        String       @default("Activo") @db.VarChar(20)
  creadoEn      DateTime     @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn DateTime?    @map("actualizado_en") @db.Timestamptz(6)
  id            Int          @id @default(autoincrement())
  seguro        SeguroMedico @relation(fields: [seguroId], references: [id])
  tipoSeguro    TipoSeguro   @relation(fields: [tipoSeguroId], references: [id])
  paciente      Paciente     @relation(fields: [pacienteId], references: [usuarioId])

  @@index([pacienteId], map: "idx_paciente_seguros_usuario")
  @@map("pacientes_seguros")
}

model CaracteristicaEspecial {
  pacienteId    Int             @map("id_usuario")
  condicionId   Int             @map("id_condicion")
  notas         String?
  estado        String          @default("Activo") @db.VarChar(20)
  registradoEn  DateTime        @default(now()) @map("registrado_en") @db.Timestamptz(6)
  actualizadoEn DateTime?       @map("actualizado_en") @db.Timestamptz(6)
  creado_por    String?         @db.VarChar(20)
  id_doctor     Int?
  id            Int             @id @default(autoincrement())
  condicion     CondicionMedica @relation(fields: [condicionId], references: [id])
  paciente      Paciente        @relation(fields: [pacienteId], references: [usuarioId])
  doctores      Doctor?         @relation(fields: [id_doctor], references: [usuarioId], onUpdate: NoAction, map: "fk_caracteristicas_doctor")

  @@index([pacienteId], map: "idx_caracteristicas_usuario")
  @@map("caracteristicas_especiales")
}

model Horario {
  id            Int               @id @default(autoincrement()) @map("id_horario")
  doctorId      Int               @map("id_usuario")
  nombre        String            @db.VarChar(100)
  diaSemana     Int               @map("dia_semana")
  horaInicio    DateTime          @map("hora_inicio") @db.Time(6)
  horaFin       DateTime          @map("hora_fin") @db.Time(6)
  ubicacionId   Int?              @map("id_ubicacion")
  estado        String            @default("Activo") @db.VarChar(20)
  creadoEn      DateTime          @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn DateTime?         @map("actualizado_en") @db.Timestamptz(6)
  centroSaludId Int?              @map("id_centro_salud")
  centroSalud   CentroSalud?      @relation(fields: [centroSaludId], references: [usuarioId], onUpdate: NoAction)
  ubicacion     Ubicacion?        @relation(fields: [ubicacionId], references: [id], onDelete: Restrict)
  doctor        Doctor            @relation(fields: [doctorId], references: [usuarioId])
  servicios     ServicioHorario[]

  @@unique([doctorId, diaSemana, horaInicio], map: "uq_horario_conflicto")
  @@map("horarios")
}

model Servicio {
  id                      Int                       @id @default(autoincrement()) @map("id_servicio")
  doctorId                Int                       @map("id_doctor")
  tipoServicioId          Int                       @map("id_tipo_servicio")
  especialidadId          Int                       @map("id_especialidad")
  nombre                  String                    @db.VarChar(120)
  descripcion             String?
  precio                  Decimal                   @default(0.00) @db.Decimal(10, 2)
  duracionMinutos         Int                       @default(30) @map("duracion_minutos")
  sesiones                Int                       @default(1)
  maxPacientesDia         Int?                      @map("max_pacientes_dia")
  calificacionPromedio    Decimal?                  @default(0.00) @map("calificacion_promedio") @db.Decimal(3, 2)
  estado                  String                    @default("Activo") @db.VarChar(20)
  creadoEn                DateTime                  @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn           DateTime?                 @map("actualizado_en") @db.Timestamptz(6)
  id_ubicacion            Int?
  modalidad               String                    @default("Presencial") @db.VarChar(20)
  citas                   Cita[]
  imagenes                ServicioImagen[]
  doctor                  Doctor                    @relation(fields: [doctorId], references: [usuarioId])
  especialidad            Especialidad              @relation(fields: [especialidadId], references: [id])
  tipoServicio            TipoServicio              @relation(fields: [tipoServicioId], references: [id])
  ubicaciones             Ubicacion?                @relation(fields: [id_ubicacion], references: [id], onUpdate: NoAction)
  servicios_centros_salud servicios_centros_salud[]
  horarios                ServicioHorario[]

